# Keep the published archive to library source, the example's source, and docs.
# Everything below is dev-only noise or is rehosted elsewhere.

# OS / IDE / build artifacts
.DS_Store
.idea/
build/
.dart_tool/

# Dev-only docs. The README embeds the demo gif and the cover image via
# absolute GitHub URLs, so neither the 18 MB screenshots/ folder nor the root
# assets/ cover needs to ship. (Rooted so example/assets/ fonts still ship.)
AGENTS.md
screenshots/
/assets/

# Internal planning artifacts (2.0 rebuild specs/plans). Kept in git for project
# history, but not part of the published package (also avoids Pub's docs -> doc
# naming warning).
docs/

# Example app: publish only its Dart source and manifest, not the generated
# platform shells (android/ios/web/desktop) or local tooling state.
example/.DS_Store
example/.idea/
example/.dart_tool/
example/build/
example/.metadata
example/.flutter-plugins-dependencies
example/pubspec.lock
example/*.iml
example/android/
example/ios/
example/linux/
example/macos/
example/web/
example/windows/
